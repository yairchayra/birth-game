rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null &&
                      request.auth.token.email == 'yairrahmany@gmail.com' &&
                      request.resource.size < 500 * 1024 * 1024; // 500 MB max
    }
  }
}
